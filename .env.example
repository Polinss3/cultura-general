EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Sentry (crash reporting). Leave empty in local dev to disable.
EXPO_PUBLIC_SENTRY_DSN=

# Build-time only (NOT EXPO_PUBLIC_) — used to upload source maps to Sentry.
# Configure these in EAS with `eas env:create`.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
