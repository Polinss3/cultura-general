EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# AdMob Ad Unit IDs. Do not use App IDs here (those contain "~").
# Development builds use Google test IDs automatically via __DEV__.
# Interstitial = anuncios automáticos (diaria, contrarreloj, aprender, ascenso).
EXPO_PUBLIC_ADMOB_IOS_INTERSTITIAL_ID=ca-app-pub-3235517249572183/9345282830
EXPO_PUBLIC_ADMOB_ANDROID_INTERSTITIAL_ID=ca-app-pub-xxxxxxxxxxxxxxxx/yyyyyyyyyy
# Rewarded (Bonificado) = anuncios opcionales para ganar monedas / vida extra.
EXPO_PUBLIC_ADMOB_IOS_REWARDED_ID=ca-app-pub-3235517249572183/3295883766
EXPO_PUBLIC_ADMOB_ANDROID_REWARDED_ID=ca-app-pub-xxxxxxxxxxxxxxxx/yyyyyyyyyy

# Sentry: el DSN está hardcoded en app/_layout.tsx (es público por diseño).
# Las siguientes son SOLO de build (NO EXPO_PUBLIC_) y se usan para subir
# los source maps a Sentry. Defínelas en EAS con `eas env:create`:
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=pablo-brasero
# SENTRY_PROJECT=react-native
