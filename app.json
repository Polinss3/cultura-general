{
  "expo": {
    "name": "Cultura General",
    "slug": "cultura-general",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "culturalgeneral",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0a0a0a",
    "primaryColor": "#e8a030",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.polinss3.culturalgeneral",
      "buildNumber": "34",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "La app no usa la cámara.",
        "NSUserNotificationsUsageDescription": "Recibe un recordatorio diario para responder la pregunta del día y mantener tu racha.",
        "NSUserTrackingUsageDescription": "Tu permiso nos permite mostrarte anuncios más relevantes y mantener la app gratis. Puedes cambiarlo en cualquier momento desde Ajustes.",
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleAllowMixedLocalizations": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.polinss3.culturalgeneral",
      "versionCode": 3,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#0a0a0a",
          "imageWidth": 200
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true
        }
      ],
      "expo-asset",
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "Tu permiso nos permite mostrarte anuncios más relevantes y mantener la app gratis. Puedes cambiarlo en cualquier momento desde Ajustes."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#e8a030",
          "sounds": [],
          "mode": "production"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3235517249572183~6818966509",
          "iosAppId": "ca-app-pub-3235517249572183~4284527843",
          "delayAppMeasurementInit": true,
          "skAdNetworkItems": [
            "cstr6suwn9.skadnetwork",
            "4fzdc2evr5.skadnetwork",
            "2fnua5tdw4.skadnetwork",
            "ydx93a7ass.skadnetwork"
          ]
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "pablo-brasero"
        }
      ],
      "expo-apple-authentication",
      "expo-web-browser",
      [
        "react-native-fbsdk-next",
        {
          "appID": "996686176323860",
          "clientToken": "a75d1a12972b7429f36cbeca78ee4aab",
          "displayName": "Cultura General",
          "scheme": "fb996686176323860",
          "advertiserIDCollectionEnabled": true,
          "autoLogAppEventsEnabled": true,
          "isAutoInitEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "c320cb92-68f2-4474-9414-750921c2ac79"
      }
    },
    "owner": "pablobrasero"
  }
}
