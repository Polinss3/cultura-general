{
  "expo": {
    "name": "CG Trivia",
    "slug": "cultura-general",
    "version": "1.3.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "culturalgeneral",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0a0a0a",
    "primaryColor": "#e8a030",
    "locales": {
      "es": "./locales/native/es.json",
      "en": "./locales/native/en.json"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.polinss3.culturalgeneral",
      "buildNumber": "44",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "The app does not use the camera.",
        "NSUserNotificationsUsageDescription": "Get a daily reminder to answer the question of the day and keep your streak.",
        "NSUserTrackingUsageDescription": "Your permission helps us measure which ads lead people to the app, show more relevant advertising, and keep the app free.",
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleAllowMixedLocalizations": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.polinss3.culturalgeneral",
      "versionCode": 6,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#0a0a0a",
          "imageWidth": 200
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true
        }
      ],
      "expo-asset",
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "Your permission helps us measure which ads lead people to the app, show more relevant advertising, and keep the app free."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#e8a030",
          "sounds": [],
          "mode": "production"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3235517249572183~6818966509",
          "iosAppId": "ca-app-pub-3235517249572183~4284527843",
          "delayAppMeasurementInit": true,
          "skAdNetworkItems": [
            "cstr6suwn9.skadnetwork",
            "4fzdc2evr5.skadnetwork",
            "2fnua5tdw4.skadnetwork",
            "ydx93a7ass.skadnetwork"
          ]
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "pablo-brasero"
        }
      ],
      "expo-apple-authentication",
      "expo-web-browser",
      [
        "react-native-fbsdk-next",
        {
          "appID": "996686176323860",
          "clientToken": "a75d1a12972b7429f36cbeca78ee4aab",
          "displayName": "Cultura General",
          "scheme": "fb996686176323860",
          "advertiserIDCollectionEnabled": true,
          "autoLogAppEventsEnabled": true,
          "isAutoInitEnabled": true
        }
      ],
      "expo-localization",
      "react-native-appsflyer"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "c320cb92-68f2-4474-9414-750921c2ac79"
      }
    },
    "owner": "pablobrasero"
  }
}
